{%- if site.footer.socialLinks and (site.footer.socialLinks | length) > 0 -%}
<div class="c-footer-social">
  <ul class="c-footer-social__list">
    {%- for social in site.footer.socialLinks %}
    <li class="c-footer-social__item">
      <a class="c-footer-social__link c-footer-social__link--{{ social.platform }}"
         href="{{ social.href }}"
         aria-label="{{ social.ariaLabel | default(social.label) }}"
         target="_blank"
         rel="noopener noreferrer">
        <span class="c-footer-social__icon" aria-hidden="true"></span>
        <span class="u-sr-only">{{ social.ariaLabel | default(social.label) }}</span>
      </a>
    </li>
    {%- endfor %}
  </ul>
</div>
{%- endif -%}
