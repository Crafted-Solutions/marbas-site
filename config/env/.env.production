# Production Environment Configuration
# Public configuration - safe to commit to git

# Site Configuration
SITE_NAME=Your Site Name
DEFAULT_LANGUAGE=de
SUPPORTED_LANGUAGES=[{"code":"de","iso":"de-DE","name":"Deutsch"},{"code":"en","iso":"en-EN","name":"English"}]
FILES_DIRECTORY=./pages

# Environment-specific settings
BASE_HREF=
SITE_URL=https://your-domain.com
DOMAIN=your-domain.com
WEBPACK_CONFIG=production

# Build Configuration
LOG_LEVEL=normal

# Optional Editor Configuration
EDITOR_ENABLED=false
EDITOR_CONTENT_DIRECTORY=./pages
EDITOR_ARCHIVE_DIRECTORY=./.page-versions
EDITOR_ROUTE_PREFIX=/__editor
EDITOR_BUILD_TARGET_ENV=production

# FTP Server Settings (non-sensitive)
FTP_HOST=your-production-ftp-server.com
FTP_PORT=21
FTP_ROOT_PATH=/public_html
FTP_USE_PASSIVE=true
FTP_TIMEOUT=30000
FTP_SECURE=false
