{# ejected: external CSS mode — replaces Marbas CSS with Bootstrap CDN #}
{# @name: Seitenlayout (Basis) #}
{# @description: Globales HTML-Layout mit externem CSS-Framework. #}
{# @category: layout #}

<!DOCTYPE html>
<html lang="{{pageLanguage}}">

  <head>
    <base href="">
    {% siteMeta %}

    <link rel="icon" href="/favicon.ico" sizes="32x32">

    <!-- External CSS framework (Bootstrap CDN) — cssMode: external -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <!-- JavaScript bundles -->
    <script src="{{ '/_assets/js/main.bundle.js' | url }}" defer></script>
    <script src="{{ '/_assets/js/custom.bundle.js' | url }}" defer></script>
  </head>

  <body>
    <main id="main-content" class="container py-4">
      {% set hasPageTitle = (title | default('') | trim) != '' %}
      {% if hasPageTitle %}
      <h1>{{ title }}</h1>
      {% endif %}
      {{ content | safe }}
    </main>
  </body>

</html>
